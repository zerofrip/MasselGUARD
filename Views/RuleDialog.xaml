<Window x:Class="MasselGUARD.Views.RuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MasselGUARD"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource Accent}"
            BorderThickness="1" CornerRadius="{DynamicResource Theme.CornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Border Grid.Row="0" Background="{DynamicResource WindowBg}"
                    CornerRadius="{DynamicResource Theme.CornerRadiusTop}"
                    MouseLeftButtonDown="Title_MouseDown">
                <TextBlock x:Name="DialogTitle"
                           Text="{Binding [RuleDialogAddTitle], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource Accent}"
                           Margin="16,0" VerticalAlignment="Center"/>
            </Border>

            <!-- Fields -->
            <StackPanel Grid.Row="1" Margin="20,14,20,14">

                <!-- Name -->
                <TextBlock Text="{Binding [RuleDialogNameLabel], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}"
                           FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Margin="0,0,0,12"
                         TextChanged="NameBox_TextChanged"/>

                <!-- SSID -->
                <TextBlock Text="{Binding [RuleDialogSsidLabel], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}"
                           FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="SsidBox" Margin="0,0,8,0"
                             TextChanged="SsidBox_TextChanged"/>
                    <Button Grid.Column="1"
                            Content="{Binding [BtnUseCurrent], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource FlatBtn}"
                            FontSize="10" Padding="10,6" Click="UseCurrent_Click"/>
                </Grid>

                <!-- Tunnel -->
                <TextBlock Text="{Binding [RuleDialogTunnelLabel], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}"
                           FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                <ComboBox x:Name="TunnelBox" IsEditable="True" Margin="0,0,0,4"
                          SelectionChanged="TunnelBox_Changed"/>

                <TextBlock Text="{Binding [RuleDialogTunnelHint], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}"
                           FontSize="9" Foreground="{DynamicResource TextMuted}"
                           TextWrapping="Wrap"/>

                <!-- Trigger counter (edit mode only) -->
                <StackPanel x:Name="CounterRow" Visibility="Collapsed" Margin="0,14,0,0">
                    <!-- Full-width separator -->
                    <Border Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Label + count -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding [RuleDialogTriggerLabel], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}"
                                       FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                            <TextBlock x:Name="TriggerCountLabel"
                                       FontFamily="{DynamicResource Theme.FontFamily}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource Accent}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- (Re)set button -->
                        <Button x:Name="SetCounterBtn"
                                Grid.Column="1"
                                Content="{Binding [RuleDialogSetCounterBtn], Source={x:Static local:Lang.Instance}}"
                                Style="{StaticResource FlatBtn}"
                                FontSize="10" Padding="10,6"
                                VerticalAlignment="Bottom"
                                Margin="12,0,0,0"
                                Click="SetCounter_Click"/>
                    </Grid>
                </StackPanel>

            </StackPanel>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="{DynamicResource WindowBg}" CornerRadius="{DynamicResource Theme.CornerRadiusBottom}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="0,8,16,8" VerticalAlignment="Center">
                    <Button Content="{Binding [BtnCancel], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource FlatBtn}"
                            Margin="0,0,8,0" Click="Cancel_Click"/>
                    <Button Content="{Binding [BtnOk], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource PrimaryBtn}"
                            Click="Save_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
