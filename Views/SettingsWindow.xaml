<Window x:Class="MasselGUARD.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MasselGUARD"
        Title="{Binding [SettingsTitle], Source={x:Static local:Lang.Instance}}"
        Width="700" Height="560"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource Accent}"
            BorderThickness="1" CornerRadius="{DynamicResource Theme.CornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource Surface}"
                    CornerRadius="{DynamicResource Theme.CornerRadiusTop}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="{Binding [SettingsTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}"
                               VerticalAlignment="Center" Margin="16,0"/>
                    <Button Content="&#x2715;" Style="{StaticResource DangerBtn}"
                            HorizontalAlignment="Right"
                            Padding="10,4" Margin="0,0,8,0"
                            BorderThickness="0" Background="Transparent"
                            Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <!-- Tab body -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="155"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tab sidebar -->
                <Border Grid.Column="0" Background="{DynamicResource Surface}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,12,0,0">
                            <Button x:Name="TabBtnGeneral"       Style="{StaticResource SideTabBtn}" Click="TabBtn_Click" Tag="General"
                                    Content="{Binding [SettingsTabGeneral],       Source={x:Static local:Lang.Instance}}"/>
                            <Button x:Name="TabBtnGroups"        Style="{StaticResource SideTabBtn}" Click="TabBtn_Click" Tag="Groups"
                                    Content="{Binding [SettingsTabGroups],        Source={x:Static local:Lang.Instance}}"/>
                            <Button x:Name="TabBtnAppearance"    Style="{StaticResource SideTabBtn}" Click="TabBtn_Click" Tag="Appearance"
                                    Content="{Binding [SettingsTabAppearance],    Source={x:Static local:Lang.Instance}}"/>
                            <Button x:Name="TabBtnDefaultAction" Style="{StaticResource SideTabBtn}" Click="TabBtn_Click" Tag="DefaultAction"
                                    Content="{Binding [SettingsTabDefaultAction], Source={x:Static local:Lang.Instance}}"/>
                            <Button x:Name="TabBtnRules"         Style="{StaticResource SideTabBtn}" Click="TabBtn_Click" Tag="Rules"
                                    Content="{Binding [SettingsTabRules],         Source={x:Static local:Lang.Instance}}"/>
                            <Button x:Name="TabBtnAdvanced"      Style="{StaticResource SideTabBtn}" Click="TabBtn_Click" Tag="Advanced"
                                    Content="{Binding [SettingsTabAdvanced],      Source={x:Static local:Lang.Instance}}"/>
                            <Button x:Name="TabBtnAbout"         Style="{StaticResource SideTabBtn}" Click="TabBtn_Click" Tag="About"
                                    Content="{Binding [SettingsTabAbout],         Source={x:Static local:Lang.Instance}}"/>
                        </StackPanel>
                        <!-- Wizard button pinned at bottom of sidebar -->
                        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
                            <Button Style="{StaticResource SideTabBtn}" Click="RunWizard_Click"
                                    Content="{Binding [WizardRunAgain], Source={x:Static local:Lang.Instance}}"
                                    Padding="12,12" TextBlock.Foreground="{DynamicResource TextMuted}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Tab pages -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20,16,20,16">

                        <!-- ══ GENERAL PAGE ══════════════════════════════════ -->
                        <StackPanel x:Name="PageGeneral">

                            <!-- Language (top of General) -->
                            <TextBlock Text="{Binding [SettingsSectionLanguage], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding [SettingsLanguageLabel], Source={x:Static local:Lang.Instance}}"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="LanguagePicker"
                                              MinWidth="160" FontSize="11" Padding="6,4"
                                              SelectionChanged="LanguagePicker_SelectionChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{DynamicResource Accent}"
                                                            CornerRadius="2" Padding="4,1" Margin="0,0,7,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Code}"
                                                                   FontFamily="Consolas" FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource WindowBg}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontFamily="{DynamicResource Theme.FontFamily}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- ── APPEARANCE moved to its own tab ── -->

                            <!-- App Mode -->
                            <TextBlock Text="{Binding [SettingsSectionAppMode], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <StackPanel>
                                    <RadioButton x:Name="ModeStandalone" GroupName="AppMode" Checked="Mode_Changed"
                                                 Style="{StaticResource ModeRadio}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding [ModeStandaloneLabel], Source={x:Static local:Lang.Instance}}"
                                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding [ModeStandaloneDesc], Source={x:Static local:Lang.Instance}}"
                                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9" Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton x:Name="ModeCompanion" GroupName="AppMode" Checked="Mode_Changed"
                                                 Style="{StaticResource ModeRadio}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding [ModeCompanionLabel], Source={x:Static local:Lang.Instance}}"
                                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding [ModeCompanionDesc], Source={x:Static local:Lang.Instance}}"
                                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9" Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton x:Name="ModeMixed" GroupName="AppMode" Checked="Mode_Changed"
                                                 Style="{StaticResource ModeRadio}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding [ModeMixedLabel], Source={x:Static local:Lang.Instance}}"
                                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding [ModeMixedDesc], Source={x:Static local:Lang.Instance}}"
                                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9" Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <Border x:Name="DllStatusPanel" Background="{DynamicResource Surface}"
                                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                            CornerRadius="3" Padding="10,7" Margin="0,10,0,0">
                                        <TextBlock x:Name="DllStatusLabel" FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Interface -->
                            <TextBlock Text="Interface"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Show activity log"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="Display the activity log panel on the right side of the main window."
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="ShowActivityLogToggle"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Checked="ShowActivityLog_Changed"
                                                  Unchecked="ShowActivityLog_Changed"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                        </StackPanel>

                        <!-- ══ GROUPS PAGE ══════════════════════════ -->
                        <StackPanel x:Name="PageGroups" Visibility="Collapsed">

                            <!-- Page title -->
                            <TextBlock Text="{Binding [SettingsTabGroups], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>

                            <!-- Group list + add row (top) -->
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,12">
                                <StackPanel>
                                    <!-- Add new group row at top -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="NewGroupNameBox"
                                                 FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                 Padding="8,5" Margin="0,0,6,0">
                                            <TextBox.Resources>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}"/>
                                            </TextBox.Resources>
                                        </TextBox>
                                        <Button Grid.Column="1"
                                                Content="{Binding [BtnAddGroup], Source={x:Static local:Lang.Instance}}"
                                                Style="{StaticResource SuccessBtn}" FontSize="10" Padding="10,5"
                                                Click="AddGroup_Click"/>
                                    </Grid>
                                    <!-- Group list -->
                                    <ItemsControl x:Name="GroupListPanel"/>
                                </StackPanel>
                            </Border>

                            <!-- Display toggles (below) -->
                            <TextBlock Text="{Binding [SettingsSectionDisplay], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>

                            <!-- Always hide tunnel count toggle -->
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding [SettingsHideTunnelCount], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding [SettingsHideTunnelCountDesc], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="HideTunnelCountToggle"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Checked="HideTunnelCount_Changed"
                                                  Unchecked="HideTunnelCount_Changed"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Hide empty tunnel groups toggle -->
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding [SettingsHideEmptyGroups], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding [SettingsHideEmptyGroupsDesc], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="HideEmptyGroupsToggle"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Checked="HideEmptyGroups_Changed"
                                                  Unchecked="HideEmptyGroups_Changed"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                        </StackPanel>

                        <!-- ══ WIFI RULES PAGE ══════════════════════════ -->
                        <StackPanel x:Name="PageRules" Visibility="Collapsed">

                            <!-- Rules list (top) -->
                            <TextBlock Text="{Binding [SettingsSectionRules], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <StackPanel x:Name="AutomationPanel">
                                <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                    <StackPanel>
                                        <ListView x:Name="RulesListView" MinHeight="60" MaxHeight="220"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  SelectionChanged="RulesListView_SelectionChanged"
                                                  BorderThickness="0">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="{Binding [RuleColSsid], Source={x:Static local:Lang.Instance}}"
                                                                    Width="180" DisplayMemberBinding="{Binding Ssid}"/>
                                                    <GridViewColumn Header="{Binding [RuleColTunnel], Source={x:Static local:Lang.Instance}}"
                                                                    Width="180" DisplayMemberBinding="{Binding TunnelDisplay}"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </StackPanel>
                                </Border>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="{Binding [BtnAddRule], Source={x:Static local:Lang.Instance}}"
                                            Style="{StaticResource SuccessBtn}" FontSize="10" Padding="10,3"
                                            Click="AddRule_Click"/>
                                    <Button Content="{Binding [BtnEditRule], Source={x:Static local:Lang.Instance}}"
                                            Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,3"
                                            Margin="6,0,0,0" Click="EditRule_Click"
                                            x:Name="EditBtn" IsEnabled="False"/>
                                    <Button Content="{Binding [BtnDeleteRule], Source={x:Static local:Lang.Instance}}"
                                            Style="{StaticResource DangerBtn}" FontSize="10" Padding="10,3"
                                            Margin="6,0,0,0" Click="DeleteRule_Click"
                                            x:Name="DeleteBtn" IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Automation settings (below rules) -->
                            <TextBlock Text="{Binding [SettingsSectionMode], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>

                            <!-- Disable WiFi rules toggle -->
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding [SettingsDisableWifiRulesLabel], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding [SettingsDisableWifiRulesDesc], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9" Foreground="{DynamicResource TextMuted}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="ManualModeToggle"
                                                  Width="44" Height="22" Margin="12,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Checked="ManualMode_Changed" Unchecked="ManualMode_Changed"
                                                  Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                            </Border>

                            <!-- Hide WiFi rules on main window toggle -->
                            <Border Style="{StaticResource SettingsCard}" Margin="0,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding [SettingsHideWifiRules], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding [SettingsHideWifiRulesDesc], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="HideWifiRulesToggle"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Checked="HideWifiRules_Changed"
                                                  Unchecked="HideWifiRules_Changed"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Show rules column toggle -->
                            <Border Style="{StaticResource SettingsCard}" Margin="0,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding [SettingsShowRulesColumn], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding [SettingsShowRulesColumnDesc], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="ShowRulesColumnToggle"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Checked="ShowRulesColumn_Changed"
                                                  Unchecked="ShowRulesColumn_Changed"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                        </StackPanel>

                        <!-- ══ DEFAULT ACTION PAGE ══════════════════════════ -->
                        <StackPanel x:Name="PageDefaultAction" Visibility="Collapsed">

                            <!-- WiFi Default Action -->
                            <TextBlock Text="{Binding [SettingsSectionDefaultAction], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Background="{DynamicResource Surface}"
                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="{DynamicResource Theme.CornerRadius}"
                                    Padding="10,8" Margin="0,0,0,6">
                                <TextBlock Text="{Binding [SettingsDefaultActionInfo], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                            </Border>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,20">
                                <StackPanel>
                                    <RadioButton x:Name="ActionNone"
                                                 Content="{Binding [DefaultActionNone], Source={x:Static local:Lang.Instance}}"
                                                 Checked="DefaultAction_Changed" Tag="none" Margin="0,0,0,6"/>
                                    <RadioButton x:Name="ActionDiscon"
                                                 Content="{Binding [DefaultActionDisconnect], Source={x:Static local:Lang.Instance}}"
                                                 Checked="DefaultAction_Changed" Tag="disconnect" Margin="0,0,0,6"/>
                                    <RadioButton x:Name="ActionActivate"
                                                 Checked="DefaultAction_Changed" Tag="activate">
                                        <RadioButton.Content>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding [DefaultActionActivate], Source={x:Static local:Lang.Instance}}"
                                                           VerticalAlignment="Center"/>
                                                <ComboBox x:Name="DefaultTunnelBox" Margin="8,0,0,0"
                                                          MinWidth="140" FontSize="11" IsEditable="True"
                                                          SelectionChanged="DefaultTunnelBox_SelectionChanged"
                                                          LostFocus="DefaultTunnelBox_LostFocus"/>
                                            </StackPanel>
                                        </RadioButton.Content>
                                    </RadioButton>
                                </StackPanel>
                            </Border>

                            <!-- ── OPEN NETWORK PROTECTION ──────────────────────── -->
                            <TextBlock Text="{Binding [SettingsSectionOpenWifi], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Background="{DynamicResource Surface}"
                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="{DynamicResource Theme.CornerRadius}"
                                    Padding="10,8" Margin="0,0,0,6">
                                <TextBlock Text="{Binding [SettingsOpenWifiInfo], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                            </Border>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding [OpenWifiTunnel], Source={x:Static local:Lang.Instance}}"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="OpenWifiTunnelBox"
                                              MinWidth="160" FontSize="11"
                                              SelectionChanged="OpenWifiTunnel_Changed"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- ══ APPEARANCE PAGE ══════════════════════════════ -->
                        <StackPanel x:Name="PageAppearance" Visibility="Collapsed">

                            <!-- System theme section -->
                            <TextBlock Text="{Binding [SettingsSectionTheme], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding [SettingsThemeAutoLabel], Source={x:Static local:Lang.Instance}}"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="{Binding [SettingsThemeAutoDesc], Source={x:Static local:Lang.Instance}}"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                               Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap" Margin="0,2,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="SysModeLight" GroupName="SysMode" Tag="light"
                                                     Content="Light"
                                                     Style="{StaticResource PillRadio}"
                                                     Checked="SystemMode_Changed"/>
                                        <RadioButton x:Name="SysModeDark" GroupName="SysMode" Tag="dark"
                                                     Content="Dark"
                                                     Style="{StaticResource PillRadio}" Margin="6,0,0,0"
                                                     Checked="SystemMode_Changed"/>
                                        <RadioButton x:Name="SysModeAuto" GroupName="SysMode" Tag="auto"
                                                     Content="Auto"
                                                     Style="{StaticResource PillRadio}" Margin="6,0,0,0"
                                                     Checked="SystemMode_Changed"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Custom appearance toggle -->
                            <TextBlock Text="Custom appearance"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Use custom theme"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="Enable theme files for dark and light mode. When off, Windows 11 colors are used."
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="CustomThemeToggle"
                                                  Width="44" Height="22" Margin="12,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Checked="CustomTheme_Changed" Unchecked="CustomTheme_Changed"/>
                                </Grid>
                            </Border>

                            <!-- Theme pickers — only visible when custom theme is on -->
                            <StackPanel x:Name="CustomThemePickersPanel" Visibility="Collapsed">

                                <!-- Dark theme -->
                                <TextBlock Text="{Binding [SettingsThemeDarkLabel], Source={x:Static local:Lang.Instance}}"
                                           Style="{StaticResource SettingsSectionHeader}"/>
                                <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                    <ComboBox x:Name="DarkThemePicker" Padding="8,4"
                                              SelectionChanged="DarkThemePicker_SelectionChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontFamily="{DynamicResource Theme.FontFamily}"
                                                           FontSize="11" Foreground="{DynamicResource TextPrimary}"
                                                           Margin="0,2"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Border>
                                <Border x:Name="DarkThemeInfoPanel" Style="{StaticResource SettingsCard}"
                                        Margin="0,0,0,4" Visibility="Collapsed">
                                    <TextBlock x:Name="DarkThemeInfoText"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                               Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                </Border>
                                <!-- Dark theme preview button -->
                                <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Preview dark theme for 10 seconds."
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <Button Grid.Column="1" x:Name="DarkThemePreviewBtn"
                                                Content="▶  Preview" FontSize="9" Padding="8,3"
                                                Width="76"
                                                Style="{StaticResource FlatBtn}"
                                                Foreground="{DynamicResource TextMuted}"
                                                VerticalAlignment="Center"
                                                Margin="10,0,0,0"
                                                Click="DarkThemePreview_Click"
                                                ToolTip="Preview the dark theme for 10 s — works regardless of current system mode"/>
                                    </Grid>
                                </Border>

                                <!-- Light theme -->
                                <TextBlock Text="{Binding [SettingsThemeLightLabel], Source={x:Static local:Lang.Instance}}"
                                           Style="{StaticResource SettingsSectionHeader}"/>
                                <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                    <ComboBox x:Name="LightThemePicker" Padding="8,4"
                                              SelectionChanged="LightThemePicker_SelectionChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontFamily="{DynamicResource Theme.FontFamily}"
                                                           FontSize="11" Foreground="{DynamicResource TextPrimary}"
                                                           Margin="0,2"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Border>
                                <Border x:Name="LightThemeInfoPanel" Style="{StaticResource SettingsCard}"
                                        Margin="0,0,0,4" Visibility="Collapsed">
                                    <TextBlock x:Name="LightThemeInfoText"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                               Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                </Border>
                                <!-- Light theme preview button -->
                                <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Preview light theme for 10 seconds."
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <Button Grid.Column="1" x:Name="LightThemePreviewBtn"
                                                Content="▶  Preview" FontSize="9" Padding="8,3"
                                                Width="76"
                                                Style="{StaticResource FlatBtn}"
                                                Foreground="{DynamicResource TextMuted}"
                                                VerticalAlignment="Center"
                                                Margin="10,0,0,0"
                                                Click="LightThemePreview_Click"
                                                ToolTip="Preview the light theme for 10 s — works regardless of current system mode"/>
                                    </Grid>
                                </Border>

                            </StackPanel>

                            <!-- ── Font override ─────────────────────────────── -->
                            <TextBlock Text="Font"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Override font"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="Replace the theme font with a custom typeface."
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="FontOverrideToggle"
                                                  Width="44" Height="22" Margin="12,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Checked="FontOverride_Changed"
                                                  Unchecked="FontOverride_Changed"/>
                                </Grid>
                            </Border>

                            <StackPanel x:Name="FontPickerPanel" Visibility="Collapsed" Margin="0,0,0,16">
                                <!-- Font family picker -->
                                <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock Text="Font family"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="FontFamilyPicker"
                                                  IsEditable="True"
                                                  MaxDropDownHeight="220"
                                                  FontSize="11" Padding="6,4"
                                                  TextSearch.TextPath="DisplayName"
                                                  SelectionChanged="FontFamilyPicker_Changed"
                                                  LostFocus="FontFamilyPicker_LostFocus">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontFamily="{Binding FontFamily}"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Text="Leave blank to use the Windows system UI font."
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <!-- Live preview — between picker and slider so you see the font before sizing -->
                                <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock Text="Preview"
                                                   FontSize="9" Foreground="{DynamicResource TextMuted}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock x:Name="FontPreviewLabel"
                                                   Text="MasselGUARD — 1.MasselinkVPN-Split-AG — Connected 3m 55s"
                                                   FontSize="11" Foreground="{DynamicResource TextPrimary}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <!-- Font size slider + preview button -->
                                <Border Style="{StaticResource SettingsCard}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Font size"
                                                       FontFamily="{DynamicResource Theme.FontFamily}"
                                                       FontSize="10" Foreground="{DynamicResource TextMuted}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" x:Name="FontSizeValueLabel"
                                                       FontFamily="{DynamicResource Theme.FontFamily}"
                                                       FontSize="10" Foreground="{DynamicResource TextPrimary}"
                                                       VerticalAlignment="Center" Text="12 pt"/>
                                        </Grid>
                                        <!-- min────●────max  [▶ Preview] -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Grid.Column="0" x:Name="FontSizeSlider"
                                                    Minimum="8" Maximum="18" Value="12"
                                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                                    SmallChange="1" LargeChange="2"
                                                    VerticalAlignment="Center"
                                                    ValueChanged="FontSizeSlider_Changed"/>
                                            <Button Grid.Column="1" x:Name="FontPreviewBtn"
                                                    Content="▶  Preview" FontSize="9" Padding="8,3"
                                                    Width="76"
                                                    Style="{StaticResource FlatBtn}"
                                                    Foreground="{DynamicResource TextMuted}"
                                                    VerticalAlignment="Center"
                                                    Margin="10,0,0,0"
                                                    Click="FontPreview_Click"
                                                    ToolTip="Apply this font to the whole interface for 10 s"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Notifications -->
                            <TextBlock Text="{Binding [SettingsTrayPopupLabel], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding [SettingsTrayPopupLabel], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding [SettingsTrayPopup], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="TrayPopupToggle"
                                                  Width="44" Height="22" Margin="12,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Checked="TrayPopup_Changed" Unchecked="TrayPopup_Changed"/>
                                </Grid>
                            </Border>
                            <!-- Notification duration -->
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding [SettingsNotifDuration], Source={x:Static local:Lang.Instance}}"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="NotifDurationPicker"
                                              Width="80" FontSize="11" Margin="12,0,0,0"
                                              SelectionChanged="NotifDuration_Changed"/>
                                </Grid>
                            </Border>

                        </StackPanel>

                        <!-- ══ ADVANCED PAGE ══════════════════════════════════ -->
                        <StackPanel x:Name="PageAdvanced" Visibility="Collapsed">

                            <!-- Import / Export -->
                            <TextBlock Text="{Binding [SettingsImportExportSection], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Background="{DynamicResource Surface}"
                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="{DynamicResource Theme.CornerRadius}"
                                    Padding="10,8" Margin="0,0,0,6">
                                <TextBlock Text="{Binding [SettingsImportExportInfo], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Button Content="{Binding [BtnExportSettings], Source={x:Static local:Lang.Instance}}"
                                        Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,3"
                                        Click="ExportSettings_Click"/>
                                <Button Content="{Binding [BtnImportSettings], Source={x:Static local:Lang.Instance}}"
                                        Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,3"
                                        Margin="8,0,0,0" Click="ImportSettings_Click"/>
                            </StackPanel>

                            <!-- Log level -->
                            <TextBlock Text="{Binding [SettingsSectionLog], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding [SettingsLogLevel], Source={x:Static local:Lang.Instance}}"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="LogLevelPicker"
                                              MinWidth="110" FontSize="11" Padding="8,4"
                                              SelectionChanged="LogLevel_Changed"/>
                                </Grid>
                            </Border>

                            <!-- Installation -->
                            <TextBlock Text="{Binding [SettingsSectionInstall], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="InstallStatusLabel"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Foreground="{DynamicResource TextPrimary}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="InstallPathLabel"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9" Foreground="{DynamicResource TextMuted}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        <CheckBox x:Name="SuppressUpdatePromptToggle"
                                                  FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9" Foreground="{DynamicResource TextMuted}"
                                                  Margin="0,8,0,0"
                                                  Checked="SuppressUpdatePrompt_Changed"
                                                  Unchecked="SuppressUpdatePrompt_Changed">
                                            <CheckBox.Content>
                                                <TextBlock Text="{Binding [SettingsSuppressUpdatePrompt], Source={x:Static local:Lang.Instance}}"
                                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9" Foreground="{DynamicResource TextMuted}"
                                                           TextWrapping="Wrap" MaxWidth="260"/>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="InstallBtn"
                                            Style="{StaticResource FlatBtn}"
                                            FontSize="11" Padding="14,6" Margin="12,0,0,0"
                                            VerticalAlignment="Top" Click="InstallBtn_Click"/>
                                </Grid>
                            </Border>

                            <!-- Start with Windows toggle -->
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding [SettingsStartWithWindows], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding [SettingsStartWithWindowsDesc], Source={x:Static local:Lang.Instance}}"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="StartWithWindowsToggle"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Checked="StartWithWindows_Changed"
                                                  Unchecked="StartWithWindows_Changed"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Confirm on close toggle -->
                            <Border Style="{StaticResource SettingsCard}" Margin="0,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Confirm disconnect on exit"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="When active tunnels are running, ask before disconnecting them on exit. When off, tunnels are disconnected silently."
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="ConfirmOnCloseToggle"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Checked="ConfirmOnClose_Changed"
                                                  Unchecked="ConfirmOnClose_Changed"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- WireGuard client -->
                            <TextBlock x:Name="WireGuardSectionLabel"
                                       Text="{Binding [SettingsSectionWireGuard], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border x:Name="WireGuardSectionCard" Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding [SettingsWireGuardDesc], Source={x:Static local:Lang.Instance}}"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10" Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{Binding [BtnOpenWireGuard], Source={x:Static local:Lang.Instance}}"
                                                Style="{StaticResource FlatBtn}" FontSize="10" Padding="12,6"
                                                Click="OpenWireGuard_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Orphaned services -->
                            <TextBlock Text="{Binding [SettingsSectionOrphans], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}">
                                <StackPanel>
                                    <!-- Warning banner -->
                                    <Border Background="{DynamicResource WarningBg}" BorderBrush="{DynamicResource WarningColor}"
                                            BorderThickness="1" CornerRadius="3"
                                            Padding="10,7" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="⚠  "
                                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                       Foreground="{DynamicResource WarningColor}" VerticalAlignment="Top"
                                                       Margin="0,0,2,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding [OrphansDescription], Source={x:Static local:Lang.Instance}}"
                                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                                       Foreground="{DynamicResource WarningColor}"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>

                                    <!-- Status + scan button -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="OrphanStatusLabel"
                                                   Grid.Column="0"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <Button Grid.Column="1"
                                                Content="{Binding [BtnScanOrphans], Source={x:Static local:Lang.Instance}}"
                                                Style="{StaticResource FlatBtn}"
                                                FontSize="10" Padding="12,4" Margin="8,0,0,0"
                                                Click="ScanOrphans_Click"/>
                                    </Grid>

                                    <!-- Orphan list (hidden when empty) -->
                                    <StackPanel x:Name="OrphanListPanel" Visibility="Collapsed"
                                                Margin="0,4,0,8"/>

                                    <!-- Remove all -->
                                    <Button x:Name="RemoveAllOrphansBtn"
                                            Content="{Binding [BtnRemoveAllOrphans], Source={x:Static local:Lang.Instance}}"
                                            Style="{StaticResource DangerBtn}"
                                            FontSize="10" Padding="12,5"
                                            HorizontalAlignment="Right"
                                            Visibility="Collapsed"
                                            Click="RemoveAllOrphans_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ══ ABOUT PAGE ══════════════════════════════════════ -->
                        <StackPanel x:Name="PageAbout" Visibility="Collapsed">

                            <!-- Updates -->
                            <TextBlock Text="{Binding [SettingsSectionUpdate], Source={x:Static local:Lang.Instance}}"
                                       Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <StackPanel>

                                    <!-- Version + status badge row -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="VersionLabel"
                                                       FontFamily="{DynamicResource Theme.FontFamily}"
                                                       FontSize="15" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock x:Name="LastCheckedLabel"
                                                       FontFamily="{DynamicResource Theme.FontFamily}"
                                                       FontSize="10" Foreground="{DynamicResource TextMuted}"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <!-- Status badge pill -->
                                        <Border Grid.Column="1" x:Name="UpdateStatusBadge"
                                                CornerRadius="10" Padding="10,4"
                                                VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock x:Name="UpdateStatusLabel"
                                                       FontFamily="{DynamicResource Theme.FontFamily}"
                                                       FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>

                                    <!-- Separator -->
                                    <Border Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,10"/>

                                    <!-- Frequency pills row -->
                                    <TextBlock Text="{Binding [UpdateCheckFrequencyLabel], Source={x:Static local:Lang.Instance}}"
                                               FontFamily="{DynamicResource Theme.FontFamily}"
                                               FontSize="10" Foreground="{DynamicResource TextMuted}"
                                               Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <RadioButton x:Name="FreqOnStart" GroupName="UpdateFreq"
                                                     Content="{Binding [UpdateCheckOnStart], Source={x:Static local:Lang.Instance}}"
                                                     Style="{StaticResource PillRadio}"
                                                     Checked="UpdateFreq_Changed" Tag="onstart"/>
                                        <RadioButton x:Name="FreqDaily" GroupName="UpdateFreq"
                                                     Content="{Binding [UpdateCheckDaily], Source={x:Static local:Lang.Instance}}"
                                                     Style="{StaticResource PillRadio}" Margin="6,0,0,0"
                                                     Checked="UpdateFreq_Changed" Tag="daily"/>
                                        <RadioButton x:Name="FreqWeekly" GroupName="UpdateFreq"
                                                     Content="{Binding [UpdateCheckWeekly], Source={x:Static local:Lang.Instance}}"
                                                     Style="{StaticResource PillRadio}" Margin="6,0,0,0"
                                                     Checked="UpdateFreq_Changed" Tag="weekly"/>
                                        <RadioButton x:Name="FreqManual" GroupName="UpdateFreq"
                                                     Content="{Binding [UpdateCheckManual], Source={x:Static local:Lang.Instance}}"
                                                     Style="{StaticResource PillRadio}" Margin="6,0,0,0"
                                                     Checked="UpdateFreq_Changed" Tag="manual"/>
                                    </StackPanel>

                                    <!-- Action buttons row -->
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="CheckUpdateBtn"
                                                Style="{StaticResource FlatBtn}"
                                                FontSize="10" Padding="12,6"
                                                Click="CheckUpdate_Click"/>
                                        <Button x:Name="DoUpdateBtn"
                                                Style="{StaticResource SuccessBtn}"
                                                FontSize="10" Padding="12,6" Margin="8,0,0,0"
                                                Visibility="Collapsed"
                                                Click="DoUpdate_Click"/>
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                            <!-- Credits -->
                            <Border Style="{StaticResource SettingsCard}">
                                <StackPanel>
                                    <TextBlock Text="by Harold Masselink"
                                               FontFamily="{DynamicResource Theme.FontFamily}"
                                               FontSize="10" Foreground="{DynamicResource TextMuted}"/>
                                    <TextBlock x:Name="GithubLink"
                                               Text="github.com/masselink/MasselGUARD"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                               Foreground="{DynamicResource Accent}"
                                               Cursor="Hand" TextDecorations="Underline"
                                               Margin="0,4,0,0"
                                               MouseLeftButtonUp="GithubLink_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource Surface}" CornerRadius="{DynamicResource Theme.CornerRadiusBottom}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button Content="{Binding [BtnCancel], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource FlatBtn}" Padding="20,6" Margin="0,0,8,0"
                            Click="CloseBtn_Click"/>
                    <Button x:Name="SaveBtn"
                            Content="{Binding [BtnSaveSettings], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource SuccessBtn}" Padding="20,6"
                            Click="SaveBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
