<Window x:Class="MasselGUARD.Views.TunnelMetadataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MasselGUARD"
        Title="{Binding [TunnelMetadataTitle], Source={x:Static local:Lang.Instance}}"
        Width="420" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource Accent}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Theme.CornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource Surface}"
                    CornerRadius="{DynamicResource Theme.CornerRadiusTop}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock x:Name="DialogTitle"
                               FontFamily="{DynamicResource Theme.FontFamily}"
                               FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}"
                               VerticalAlignment="Center" Margin="16,0"/>
                    <Button Content="&#x2715;" Style="{StaticResource DangerBtn}"
                            HorizontalAlignment="Right" Padding="10,4" Margin="0,0,8,0"
                            BorderThickness="0" Background="Transparent"
                            Click="CancelBtn_Click"/>
                </Grid>
            </Border>

            <!-- Fields -->
            <StackPanel Grid.Row="1" Margin="20,16,20,0">

                <!-- Tunnel name (read-only) -->
                <TextBlock Text="{Binding [TunnelDialogName], Source={x:Static local:Lang.Instance}}"
                           Style="{StaticResource FormLabel}"/>
                <TextBlock x:Name="TunnelNameLabel"
                           FontFamily="{DynamicResource Theme.FontFamily}"
                           FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,12"/>

                <!-- Info notice for WireGuard tunnels -->
                <Border Background="{DynamicResource CardBg}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        CornerRadius="{DynamicResource Theme.CornerRadius}"
                        Padding="10,8" Margin="0,0,0,14">
                    <TextBlock Text="{Binding [TunnelMetadataInfo], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}"
                               FontSize="9" Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Group picker -->
                <TextBlock Text="{Binding [TunnelDialogGroup], Source={x:Static local:Lang.Instance}}"
                           Style="{StaticResource FormLabel}"/>
                <ComboBox x:Name="GroupPicker"
                          FontFamily="{DynamicResource Theme.FontFamily}"
                          FontSize="11" Margin="0,0,0,12"/>

                <!-- Notes -->
                <TextBlock Text="{Binding [TunnelDialogNotes], Source={x:Static local:Lang.Instance}}"
                           Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="NotesBox"
                         FontFamily="{DynamicResource Theme.FontFamily}"
                         FontSize="11"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         Height="60" Margin="0,0,0,4"
                         VerticalScrollBarVisibility="Auto"/>
                <TextBlock Text="{Binding [TunnelDialogNotesHint], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}"
                           FontSize="9" Foreground="{DynamicResource TextMuted}"
                           Margin="0,0,0,14"/>

                <!-- Scripts section -->
                <TextBlock Text="{Binding [TunnelScriptsHeader], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding [TunnelScriptsInfo], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}"
                           FontSize="9" Foreground="{DynamicResource TextMuted}"
                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                <!-- Pre-connect -->
                <TextBlock Text="{Binding [TunnelScriptPreConnect], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                           FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="PreConnectBox"
                             FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Padding="6,4"/>
                    <Button Grid.Column="1" Content="{Binding [BtnBrowse], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,4"
                            Margin="4,0,0,0" Click="BrowsePreConnect_Click"/>
                </Grid>

                <!-- Post-connect -->
                <TextBlock Text="{Binding [TunnelScriptPostConnect], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                           FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="PostConnectBox"
                             FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Padding="6,4"/>
                    <Button Grid.Column="1" Content="{Binding [BtnBrowse], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,4"
                            Margin="4,0,0,0" Click="BrowsePostConnect_Click"/>
                </Grid>

                <!-- Pre-disconnect -->
                <TextBlock Text="{Binding [TunnelScriptPreDisconnect], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                           FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="PreDisconnectBox"
                             FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Padding="6,4"/>
                    <Button Grid.Column="1" Content="{Binding [BtnBrowse], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,4"
                            Margin="4,0,0,0" Click="BrowsePreDisconnect_Click"/>
                </Grid>

                <!-- Post-disconnect -->
                <TextBlock Text="{Binding [TunnelScriptPostDisconnect], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                           FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="PostDisconnectBox"
                             FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" Padding="6,4"/>
                    <Button Grid.Column="1" Content="{Binding [BtnBrowse], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,4"
                            Margin="4,0,0,0" Click="BrowsePostDisconnect_Click"/>
                </Grid>
            </StackPanel>

            <!-- Button bar -->
            <Border Grid.Row="2" Background="{DynamicResource Surface}"
                    CornerRadius="{DynamicResource Theme.CornerRadiusBottom}">
                <Grid Margin="16,10">
                    <!-- Left: toggles stacked vertically -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <!-- Row 1: Default + Open network protection -->
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="IsDefaultToggle"
                                          Style="{StaticResource ToggleSwitch}"
                                          Margin="0,0,6,0"/>
                            <TextBlock Text="⚡ Default action"
                                       FontSize="10" Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <ToggleButton x:Name="IsOpenProtectionToggle"
                                          Style="{StaticResource ToggleSwitch}"
                                          Margin="0,0,6,0"/>
                            <TextBlock Text="🔓 Open network protection"
                                       FontSize="10" Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Row 2: Kill switch -->
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <ToggleButton x:Name="KillSwitchToggle"
                                          Style="{StaticResource ToggleSwitch}"
                                          Margin="0,0,6,0"/>
                            <TextBlock x:Name="KillSwitchToggleLabel"
                                       Text="🔒 Kill switch"
                                       FontSize="10" Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Row 3: Auto-reconnect -->
                        <StackPanel x:Name="AutoReconnectRow" Orientation="Horizontal" Margin="0,6,0,0">
                            <ToggleButton x:Name="AutoReconnectToggle"
                                          Style="{StaticResource ToggleSwitch}"
                                          Margin="0,0,6,0"/>
                            <TextBlock x:Name="AutoReconnectToggleLabel"
                                       Text="🔄 Auto-reconnect"
                                       FontSize="10" Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Row 4: Skip validation -->
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <ToggleButton x:Name="SkipValidationToggle"
                                          Style="{StaticResource ToggleSwitch}"
                                          Margin="0,0,6,0"/>
                            <TextBlock Text="⚠️ Skip config validation"
                                       FontSize="10" Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Right: Cancel + Save -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="{Binding [BtnCancel], Source={x:Static local:Lang.Instance}}"
                                Style="{StaticResource FlatBtn}" Padding="20,6" Margin="0,0,8,0"
                                Click="CancelBtn_Click"/>
                        <Button Content="{Binding [BtnSaveTunnel], Source={x:Static local:Lang.Instance}}"
                                Style="{StaticResource PrimaryBtn}" Padding="20,6"
                                Click="SaveBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
