<Window x:Class="MasselGUARD.Views.WizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MasselGUARD"
        Title="{Binding [WizardTitle], Source={x:Static local:Lang.Instance}}"
        Width="500" Height="480"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource Accent}"
            BorderThickness="1" CornerRadius="{DynamicResource Theme.CornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource Surface}"
                    CornerRadius="{DynamicResource Theme.CornerRadiusTop}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="{Binding [WizardTitle], Source={x:Static local:Lang.Instance}}"
                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="13" FontWeight="Bold"
                           Foreground="{DynamicResource Accent}"
                           VerticalAlignment="Center" Margin="16,0"/>
            </Border>

            <!-- Step dots: 7 steps (0-6) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,14,0,0">
                <Ellipse x:Name="Dot0" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource Accent}"/>
                <Ellipse x:Name="Dot1" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource BorderColor}"/>
                <Ellipse x:Name="Dot2" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource BorderColor}"/>
                <Ellipse x:Name="Dot3" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource BorderColor}"/>
                <Ellipse x:Name="Dot4" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource BorderColor}"/>
                <Ellipse x:Name="Dot5" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource BorderColor}"/>
                <Ellipse x:Name="Dot6" Width="10" Height="10" Margin="4,0" Fill="{DynamicResource BorderColor}"/>
            </StackPanel>

            <!-- Step pages -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,20,32,0">

                <!-- ── Step 0: Welcome ─────────────────────────────────────── -->
                <StackPanel x:Name="Step0">
                    <TextBlock Text="{Binding [WizardWelcomeTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,10"/>

                    <!-- Upgrade notice -->
                    <Border x:Name="WizUpgradeNotice" Visibility="Collapsed"
                            Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource Accent}" BorderThickness="2,0,0,0"
                            Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="WizUpgradeTitle"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                       FontWeight="Bold" Foreground="{DynamicResource Accent}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="WizUpgradeBody"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding [WizardWelcomeBody], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,16"/>

                    <!-- Import settings card -->
                    <Border Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            CornerRadius="{DynamicResource Theme.CornerRadius}" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding [WizardImportHint], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="WizImportResultLabel"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           Foreground="{DynamicResource Success}" TextWrapping="Wrap"
                                           Margin="0,4,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="{Binding [WizardImportBtn], Source={x:Static local:Lang.Instance}}"
                                    Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,5"
                                    Margin="12,0,0,0" VerticalAlignment="Center"
                                    Click="WizImport_Click"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Step 1: Language & Appearance ──────────────────────── -->
                <StackPanel x:Name="Step1" Visibility="Collapsed">
                    <TextBlock Text="{Binding [WizardLangTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding [WizardLangBody], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                               Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <!-- Language -->
                    <TextBlock Text="{Binding [SettingsLanguageLabel], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="WizLangPicker" FontSize="11"
                              SelectionChanged="WizLang_Changed" Margin="0,0,0,20">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding FlagImage}"
                                           Width="20" Height="14"
                                           Margin="0,0,8,0" VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           SnapsToDevicePixels="True"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="{DynamicResource Theme.FontFamily}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Theme -->
                    <TextBlock Text="{Binding [WizardThemeLabel], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="WizThemeDark"
                                     Content="{Binding [WizardThemeDark], Source={x:Static local:Lang.Instance}}"
                                     FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                     Foreground="{DynamicResource TextPrimary}"
                                     Margin="0,0,20,0" GroupName="WizTheme"
                                     Checked="WizTheme_Changed"/>
                        <RadioButton x:Name="WizThemeLight"
                                     Content="{Binding [WizardThemeLight], Source={x:Static local:Lang.Instance}}"
                                     FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                     Foreground="{DynamicResource TextPrimary}"
                                     Margin="0,0,20,0" GroupName="WizTheme"
                                     Checked="WizTheme_Changed"/>
                        <RadioButton x:Name="WizThemeAuto"
                                     Content="{Binding [WizardThemeAuto], Source={x:Static local:Lang.Instance}}"
                                     FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                     Foreground="{DynamicResource TextPrimary}"
                                     GroupName="WizTheme"
                                     Checked="WizTheme_Changed"/>
                    </StackPanel>
                </StackPanel>

                <!-- ── Step 2: Operating mode ──────────────────────────────── -->
                <StackPanel x:Name="Step2" Visibility="Collapsed">
                    <TextBlock Text="{Binding [WizardModeTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding [WizardModeBody], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                               Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <RadioButton x:Name="WizModeStandalone" Grid.Column="0" GroupName="WizMode"
                                         VerticalAlignment="Center" Margin="0,0,12,0" Checked="WizMode_Changed"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding [WizardModeStandaloneLabel], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="{Binding [WizardModeStandaloneDesc], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <RadioButton x:Name="WizModeCompanion" Grid.Column="0" GroupName="WizMode"
                                         VerticalAlignment="Center" Margin="0,0,12,0" Checked="WizMode_Changed"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding [WizardModeCompanionLabel], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="{Binding [WizardModeCompanionDesc], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <RadioButton x:Name="WizModeMixed" Grid.Column="0" GroupName="WizMode"
                                         VerticalAlignment="Center" Margin="0,0,12,0" Checked="WizMode_Changed"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding [WizardModeMixedLabel], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="{Binding [WizardModeMixedDesc], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Step 3: Startup & Installation ─────────────────────── -->
                <StackPanel x:Name="Step3" Visibility="Collapsed">
                    <TextBlock Text="Startup"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,10"/>
                    <TextBlock Text="Choose how MasselGUARD is installed and whether it starts automatically with Windows."
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                               Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Install choice (first-run standalone only) -->
                    <Border x:Name="WizInstallChoice" Visibility="Collapsed"
                            Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                            CornerRadius="{DynamicResource Theme.CornerRadius}" Padding="12,10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding [WizardInstallQuestion], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                       Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding [WizardInstallPortable], Source={x:Static local:Lang.Instance}}"
                                        Style="{StaticResource FlatBtn}" FontSize="11" Padding="12,6"
                                        Margin="0,0,8,0" Click="WizRunPortable_Click"/>
                                <Button Content="{Binding [WizardInstallManaged], Source={x:Static local:Lang.Instance}}"
                                        Style="{StaticResource SuccessBtn}" FontSize="11" Padding="12,6"
                                        Click="WizInstallNow_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Start with Windows -->
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding [SettingsStartWithWindows], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="{Binding [SettingsStartWithWindowsDesc], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" x:Name="WizStartWithWindowsToggle"
                                          Width="44" Height="22" Style="{StaticResource ToggleSwitch}"
                                          Margin="12,0,0,0" VerticalAlignment="Center"
                                          Checked="WizStartWithWindows_Changed"
                                          Unchecked="WizStartWithWindows_Changed"/>
                        </Grid>
                    </Border>

                    <!-- Confirm on exit -->
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Confirm disconnect on exit"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Ask before disconnecting active tunnels when closing the app."
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" x:Name="WizConfirmOnCloseToggle"
                                          Width="44" Height="22" Style="{StaticResource ToggleSwitch}"
                                          Margin="12,0,0,0" VerticalAlignment="Center"
                                          Checked="WizConfirmOnClose_Changed"
                                          Unchecked="WizConfirmOnClose_Changed"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Step 4: WiFi Automation ─────────────────────────────── -->
                <StackPanel x:Name="Step4" Visibility="Collapsed">
                    <TextBlock Text="{Binding [SettingsTabWifi], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding [WizardManualBody], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                               Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <!-- How rules work — explanation only; rules are created after the
                         wizard (Settings → WiFi), once tunnels exist. -->
                    <Border Background="{DynamicResource Surface}"
                            BorderBrush="{DynamicResource Accent}" BorderThickness="2,0,0,0"
                            Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding [WizardRulesTitle], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                       FontWeight="Bold" Foreground="{DynamicResource Accent}"/>
                            <TextBlock Text="{Binding [WizardRulesBody], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding [WizardRuleLabelWifi], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                           Margin="0,0,8,3"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding [WizardRulesWifiHint], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                           Margin="0,0,0,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{Binding [WizardRuleLabelDefault], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                           Margin="0,0,8,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding [WizardRulesDefaultHint], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                           Margin="0,0,0,3"/>
                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="{Binding [WizardRuleLabelOpen], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                           Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding [WizardRulesOpenHint], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                            </Grid>
                            <TextBlock Text="{Binding [WizardRulesWhy], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                       FontStyle="Italic" Foreground="{DynamicResource TextMuted}"
                                       TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Disable WiFi rules toggle -->
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [WizardDisableRulesLabel], Source={x:Static local:Lang.Instance}}"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <ToggleButton Grid.Column="1" x:Name="WizManualToggle"
                                          Width="44" Height="22" Style="{StaticResource ToggleSwitch}"
                                          Margin="12,0,0,0"
                                          Checked="WizManualToggle_Changed"
                                          Unchecked="WizManualToggle_Changed"/>
                        </Grid>
                    </Border>

                    <!-- Show WiFi rules on main window (hidden when manual mode on) -->
                    <Border x:Name="WizShowRulesCard"
                            Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding [WizardShowRulesLabel], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="{Binding [WizardShowRulesDesc], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" x:Name="WizShowRulesToggle"
                                          Width="44" Height="22" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="True" Margin="12,0,0,0"
                                          Checked="WizShowRules_Changed"
                                          Unchecked="WizShowRules_Changed"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Step 5: Behavior ────────────────────────────────────── -->
                <StackPanel x:Name="Step5" Visibility="Collapsed">
                    <TextBlock Text="Behavior"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,10"/>
                    <TextBlock Text="Configure how MasselGUARD handles automatic reconnects, history recording, and notifications."
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                               Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Auto-reconnect -->
                    <TextBlock Text="Auto-reconnect"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                               FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="When a tunnel drops unexpectedly, attempt to reconnect automatically."
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                       Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="WizArOff" GroupName="WizAr" Tag="off"
                                             Content="Off"
                                             Style="{StaticResource PillRadio}"
                                             Checked="WizArMode_Changed"/>
                                <RadioButton x:Name="WizArPerTunnel" GroupName="WizAr" Tag="per-tunnel"
                                             Content="Per tunnel"
                                             Style="{StaticResource PillRadio}" Margin="6,0,0,0"
                                             Checked="WizArMode_Changed"/>
                                <RadioButton x:Name="WizArAlways" GroupName="WizAr" Tag="always"
                                             Content="Always"
                                             Style="{StaticResource PillRadio}" Margin="6,0,0,0"
                                             Checked="WizArMode_Changed"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- DNS leak indicator (tunnel display option) -->
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding [ShowDnsIndicatorLabel], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="{Binding [ShowDnsIndicatorDesc], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" x:Name="WizDnsIndicatorToggle"
                                          Width="44" Height="22" Style="{StaticResource ToggleSwitch}"
                                          Margin="12,0,0,0" VerticalAlignment="Center"
                                          Checked="WizDnsIndicator_Changed"
                                          Unchecked="WizDnsIndicator_Changed"/>
                        </Grid>
                    </Border>

                    <!-- History -->
                    <TextBlock Text="History"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                               FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,8,0,4"/>
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Record tunnel connections"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Save tunnel uptime and traffic to history."
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" x:Name="WizStoreConnectionHistoryToggle"
                                          Width="44" Height="22" Style="{StaticResource ToggleSwitch}"
                                          Margin="12,0,0,0" VerticalAlignment="Center"
                                          Checked="WizStoreConnectionHistory_Changed"
                                          Unchecked="WizStoreConnectionHistory_Changed"/>
                        </Grid>
                    </Border>
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Record WiFi networks (SSID)"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Save WiFi network connection timestamps to history."
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" x:Name="WizStoreWifiHistoryToggle"
                                          Width="44" Height="22" Style="{StaticResource ToggleSwitch}"
                                          Margin="12,0,0,0" VerticalAlignment="Center"
                                          Checked="WizStoreWifiHistory_Changed"
                                          Unchecked="WizStoreWifiHistory_Changed"/>
                        </Grid>
                    </Border>

                    <!-- Notifications -->
                    <TextBlock Text="Notifications"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                               FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding [SettingsTrayPopupLabel], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="{Binding [SettingsTrayPopup], Source={x:Static local:Lang.Instance}}"
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" x:Name="WizTrayPopupToggle"
                                          Width="44" Height="22" Style="{StaticResource ToggleSwitch}"
                                          Margin="12,0,0,0" VerticalAlignment="Center"
                                          Checked="WizTrayPopup_Changed"
                                          Unchecked="WizTrayPopup_Changed"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Step 6: Done ────────────────────────────────────────── -->
                <StackPanel x:Name="Step6" Visibility="Collapsed">
                    <TextBlock Text="{Binding [WizardDoneTitle], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding [WizardDoneBody], Source={x:Static local:Lang.Instance}}"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                               Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" Margin="0,0,0,14"/>

                    <!-- Version + update check -->
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock x:Name="WizVersionLabel" Grid.Column="0"
                                       FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                       Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            <Button x:Name="WizCheckUpdateBtn" Grid.Column="1"
                                    Style="{StaticResource FlatBtn}" FontSize="10" Padding="10,4"
                                    Margin="12,0,0,0" Click="WizCheckUpdate_Click"/>
                        </Grid>
                    </Border>

                    <!-- Summary card -->
                    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
                        <StackPanel x:Name="WizSummaryPanel"/>
                    </Border>

                    <!-- Tip card -->
                    <Border Background="{DynamicResource Surface}"
                            CornerRadius="4" Padding="12,8">
                        <TextBlock Text="{Binding [WizardDoneTip], Source={x:Static local:Lang.Instance}}"
                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

            </Grid>
            </ScrollViewer>

            <!-- Footer buttons -->
            <Border Grid.Row="3" Background="{DynamicResource Surface}"
                    CornerRadius="{DynamicResource Theme.CornerRadiusBottom}">
                <Grid Margin="16,0">
                    <Button x:Name="BtnSkip" HorizontalAlignment="Left"
                            Content="{Binding [WizardBtnSkip], Source={x:Static local:Lang.Instance}}"
                            Style="{StaticResource FlatBtn}" Padding="14,0" FontSize="11"
                            Click="BtnSkip_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnBack"
                                Content="{Binding [WizardBtnBack], Source={x:Static local:Lang.Instance}}"
                                Style="{StaticResource FlatBtn}" Padding="14,0" FontSize="11"
                                IsEnabled="False" Margin="0,0,8,0" Click="BtnBack_Click"/>
                        <Button x:Name="BtnNext"
                                Content="{Binding [WizardBtnNext], Source={x:Static local:Lang.Instance}}"
                                Style="{StaticResource SuccessBtn}" Padding="20,0" FontSize="11"
                                Click="BtnNext_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
