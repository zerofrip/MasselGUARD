<Window x:Class="MasselGUARD.Views.ThemeBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MasselGUARD"
        Title="Theme Builder"
        Width="840" Height="660"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource Accent}"
            BorderThickness="1" CornerRadius="{DynamicResource Theme.CornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="48"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource Surface}"
                    CornerRadius="{DynamicResource Theme.CornerRadiusTop}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="Theme Builder"
                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}"
                               VerticalAlignment="Center" Margin="16,0"/>
                    <Button Content="&#x2715;" Style="{StaticResource DangerBtn}"
                            HorizontalAlignment="Right" Padding="10,4" Margin="0,0,8,0"
                            BorderThickness="0" Background="Transparent"
                            Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <!-- Body: left sidebar + right editor -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="195"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left: Theme list ── -->
                <Border Grid.Column="0" Background="{DynamicResource Surface}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- New theme button -->
                        <Button Grid.Row="0" Content="+ New theme"
                                Style="{StaticResource FlatBtn}" FontSize="10"
                                HorizontalAlignment="Stretch" Margin="8,8,8,4" Padding="10,6"
                                Click="NewTheme_Click"/>

                        <!-- Theme list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Built-in header -->
                                <TextBlock Text="BUILT-IN"
                                           FontFamily="{DynamicResource Theme.FontFamily}"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="12,8,8,4"/>
                                <ListBox x:Name="BuiltinList"
                                         Background="Transparent" BorderThickness="0"
                                         SelectionChanged="ThemeList_SelectionChanged"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background"  Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding"     Value="10,5"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ListHover}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ListSelected}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>

                                <!-- Custom header -->
                                <TextBlock Text="CUSTOM"
                                           FontFamily="{DynamicResource Theme.FontFamily}"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="12,10,8,4"/>
                                <ListBox x:Name="CustomList"
                                         Background="Transparent" BorderThickness="0"
                                         SelectionChanged="ThemeList_SelectionChanged"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background"  Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding"     Value="10,5"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ListHover}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ListSelected}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>

                                <!-- Empty custom state -->
                                <TextBlock x:Name="NoCustomLabel"
                                           Text="No custom themes yet."
                                           FontFamily="{DynamicResource Theme.FontFamily}"
                                           FontSize="9" Foreground="{DynamicResource TextMuted}"
                                           Margin="12,0,8,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Delete button -->
                        <Button Grid.Row="2" x:Name="DeleteThemeBtn"
                                Content="Delete theme"
                                Style="{StaticResource DangerBtn}" FontSize="10"
                                HorizontalAlignment="Stretch" Margin="8,4,8,8" Padding="10,6"
                                IsEnabled="False" Click="DeleteTheme_Click"/>
                    </Grid>
                </Border>

                <!-- ── Right: Editor ── -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20,16,20,16">

                        <!-- Empty state -->
                        <TextBlock x:Name="EmptyStateLabel"
                                   Text="Select a theme from the list to view or edit it."
                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,60,0,0"/>

                        <!-- Editor (hidden until theme selected) -->
                        <StackPanel x:Name="EditorPanel" Visibility="Collapsed">

                            <!-- Read-only notice -->
                            <Border x:Name="ReadOnlyBanner" Visibility="Collapsed"
                                    Background="{DynamicResource Surface}"
                                    BorderBrush="{DynamicResource Accent}" BorderThickness="2,0,0,0"
                                    Padding="12,8" Margin="0,0,0,12">
                                <TextBlock Text="Built-in themes are read-only. Use  Duplicate  to create an editable copy."
                                           FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                            </Border>

                            <!-- ── Identity ──────────────────────────────────── -->
                            <TextBlock Text="Identity" Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <StackPanel>

                                    <!-- Name -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Theme name"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="ThemeName"
                                                 FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                 Padding="6,4" TextChanged="Field_Changed"/>
                                    </Grid>

                                    <!-- App name -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="App name"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="AppNameBox"
                                                 FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                 Padding="6,4" TextChanged="Field_Changed"/>
                                    </Grid>

                                    <!-- Type -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Type"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <RadioButton x:Name="TypeDark" Content="Dark"
                                                         GroupName="ThemeType" Tag="dark"
                                                         Style="{StaticResource PillRadio}"
                                                         Checked="Type_Changed"/>
                                            <RadioButton x:Name="TypeLight" Content="Light"
                                                         GroupName="ThemeType" Tag="light"
                                                         Style="{StaticResource PillRadio}" Margin="6,0,0,0"
                                                         Checked="Type_Changed"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Creator -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Creator"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="CreatorBox"
                                                 FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                 Padding="6,4" TextChanged="Field_Changed"/>
                                    </Grid>

                                    <!-- Description -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Description"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top"
                                                   Margin="0,4,0,0"/>
                                        <TextBox Grid.Column="1" x:Name="DescriptionBox"
                                                 FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                 Padding="6,4" TextWrapping="Wrap" AcceptsReturn="False"
                                                 MaxLength="150" TextChanged="Field_Changed"/>
                                    </Grid>

                                </StackPanel>
                            </Border>

                            <!-- ── Colors ─────────────────────────────────────── -->
                            <TextBlock Text="Colors" Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <!-- Color rows are built in code-behind and added here -->
                                <StackPanel x:Name="ColorsPanel"/>
                            </Border>

                            <!-- ── Typography ─────────────────────────────────── -->
                            <TextBlock Text="Typography" Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <StackPanel>

                                    <!-- Font family -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Font family"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="FontFamilyBox"
                                                 FontFamily="{DynamicResource Theme.FontFamily}" FontSize="11"
                                                 Padding="6,4" TextChanged="Field_Changed"/>
                                    </Grid>

                                    <!-- Font size -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Font size"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="FontSizeSlider"
                                                Minimum="9" Maximum="18" TickFrequency="1"
                                                IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                                ValueChanged="FontSize_Changed"/>
                                        <TextBlock Grid.Column="2" x:Name="FontSizeLabel"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Corner radius -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Corner radius"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="CornerRadiusSlider"
                                                Minimum="0" Maximum="16" TickFrequency="1"
                                                IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                                ValueChanged="CornerRadius_Changed"/>
                                        <TextBlock Grid.Column="2" x:Name="CornerRadiusLabel"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>

                                </StackPanel>
                            </Border>

                            <!-- ── Window chrome ──────────────────────────────── -->
                            <TextBlock Text="Window" Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <StackPanel>

                                    <!-- Opacity -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Opacity"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="OpacitySlider"
                                                Minimum="0.1" Maximum="1.0" SmallChange="0.05"
                                                VerticalAlignment="Center"
                                                ValueChanged="Opacity_Changed"/>
                                        <TextBlock Grid.Column="2" x:Name="OpacityLabel"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Title bar height -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Title bar height"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="TitleBarHeightSlider"
                                                Minimum="32" Maximum="72" TickFrequency="1"
                                                IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                                ValueChanged="TitleBarHeight_Changed"/>
                                        <TextBlock Grid.Column="2" x:Name="TitleBarHeightLabel"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Toggles -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <CheckBox x:Name="ShowTitleBarIconCheck" Content="Title bar icon"
                                                  FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                  Foreground="{DynamicResource TextPrimary}" Margin="0,0,16,0"
                                                  Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                                        <CheckBox x:Name="ShowTitleBarAppNameCheck" Content="App name in title bar"
                                                  FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                  Foreground="{DynamicResource TextPrimary}" Margin="0,0,16,0"
                                                  Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                                        <CheckBox x:Name="ShowResizeGripCheck" Content="Resize grip"
                                                  FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                  Foreground="{DynamicResource TextPrimary}"
                                                  Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                            <!-- ── Status bar ─────────────────────────────────── -->
                            <TextBlock Text="Status bar" Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <StackPanel>

                                    <!-- Show + height -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" x:Name="ShowStatusBarCheck" Content="Show"
                                                  FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                  Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                                                  Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                                        <Slider Grid.Column="1" x:Name="StatusBarHeightSlider"
                                                Minimum="24" Maximum="60" TickFrequency="1"
                                                IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                                ValueChanged="StatusBarHeight_Changed"/>
                                        <TextBlock Grid.Column="2" x:Name="StatusBarHeightLabel"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Name="ShowStatusWifiCheck" Content="Show WiFi name"
                                                  FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                  Foreground="{DynamicResource TextPrimary}" Margin="0,0,16,0"
                                                  Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                                        <CheckBox x:Name="ShowStatusTunnelCheck" Content="Show tunnel name"
                                                  FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                  Foreground="{DynamicResource TextPrimary}"
                                                  Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                            <!-- ── Assets ─────────────────────────────────────── -->
                            <TextBlock Text="Assets" Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <StackPanel>

                                    <!-- Logo -->
                                    <TextBlock Text="Logo  (shown in the title bar — replaces the shield icon)"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="LogoPathBox"
                                                 FontFamily="Consolas" FontSize="10"
                                                 Padding="6,4" TextChanged="Field_Changed"/>
                                        <Button Grid.Column="1" Content="Browse…" FontSize="10" Padding="8,4"
                                                Margin="6,0,0,0" Style="{StaticResource FlatBtn}"
                                                Click="BrowseLogo_Click"/>
                                        <Button Grid.Column="2" Content="Clear" FontSize="10" Padding="8,4"
                                                Margin="4,0,0,0" Style="{StaticResource FlatBtn}"
                                                Click="ClearLogo_Click"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="Width" FontFamily="{DynamicResource Theme.FontFamily}"
                                                   FontSize="10" Foreground="{DynamicResource TextMuted}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox x:Name="LogoWidthBox" Width="46"
                                                 FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                 Padding="4,3" TextChanged="Field_Changed"/>
                                        <TextBlock Text="Height" FontFamily="{DynamicResource Theme.FontFamily}"
                                                   FontSize="10" Foreground="{DynamicResource TextMuted}"
                                                   VerticalAlignment="Center" Margin="12,0,6,0"/>
                                        <TextBox x:Name="LogoHeightBox" Width="46"
                                                 FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                 Padding="4,3" TextChanged="Field_Changed"/>
                                        <!-- Logo preview -->
                                        <Border x:Name="LogoPreviewBorder" Margin="12,0,0,0"
                                                Background="{DynamicResource Surface}"
                                                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                                CornerRadius="3" Padding="6,2" Visibility="Collapsed">
                                            <Image x:Name="LogoPreviewImg" Width="28" Height="28"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- App icon -->
                                    <TextBlock Text="App icon  (tray icon and taskbar button — .ico, .png, .bmp)"
                                               FontFamily="{DynamicResource Theme.FontFamily}" FontSize="9"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="AppIconPathBox"
                                                 FontFamily="Consolas" FontSize="10"
                                                 Padding="6,4" TextChanged="Field_Changed"/>
                                        <Button Grid.Column="1" Content="Browse…" FontSize="10" Padding="8,4"
                                                Margin="6,0,0,0" Style="{StaticResource FlatBtn}"
                                                Click="BrowseIcon_Click"/>
                                        <Button Grid.Column="2" Content="Clear" FontSize="10" Padding="8,4"
                                                Margin="4,0,0,0" Style="{StaticResource FlatBtn}"
                                                Click="ClearIcon_Click"/>
                                    </Grid>

                                </StackPanel>
                            </Border>

                            <!-- ── Background image ───────────────────────────── -->
                            <TextBlock Text="Background image" Style="{StaticResource SettingsSectionHeader}"/>
                            <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,16">
                                <StackPanel>

                                    <!-- Path row -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="BgImagePathBox"
                                                 FontFamily="Consolas" FontSize="10"
                                                 Padding="6,4" TextChanged="Field_Changed"/>
                                        <Button Grid.Column="1" Content="Browse…" FontSize="10" Padding="8,4"
                                                Margin="6,0,0,0" Style="{StaticResource FlatBtn}"
                                                Click="BrowseBg_Click"/>
                                        <Button Grid.Column="2" Content="Clear" FontSize="10" Padding="8,4"
                                                Margin="4,0,0,0" Style="{StaticResource FlatBtn}"
                                                Click="ClearBg_Click"/>
                                    </Grid>

                                    <!-- Stretch mode -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Stretch"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <RadioButton x:Name="StretchFill"    Content="Fill"    GroupName="BgStretch" Tag="stretch"
                                                     Style="{StaticResource PillRadio}" Checked="BgStretch_Changed"/>
                                        <RadioButton x:Name="StretchCenter"  Content="Center"  GroupName="BgStretch" Tag="center"
                                                     Style="{StaticResource PillRadio}" Margin="6,0,0,0" Checked="BgStretch_Changed"/>
                                        <RadioButton x:Name="StretchTile"    Content="Tile"    GroupName="BgStretch" Tag="tile"
                                                     Style="{StaticResource PillRadio}" Margin="6,0,0,0" Checked="BgStretch_Changed"/>
                                        <RadioButton x:Name="StretchTopLeft" Content="Top left" GroupName="BgStretch" Tag="topLeft"
                                                     Style="{StaticResource PillRadio}" Margin="6,0,0,0" Checked="BgStretch_Changed"/>
                                    </StackPanel>

                                    <!-- Opacity -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Opacity"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" x:Name="BgOpacitySlider"
                                                Minimum="0.0" Maximum="1.0" SmallChange="0.01"
                                                VerticalAlignment="Center"
                                                ValueChanged="BgOpacity_Changed"/>
                                        <TextBlock Grid.Column="2" x:Name="BgOpacityLabel"
                                                   FontFamily="{DynamicResource Theme.FontFamily}" FontSize="10"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>

                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── Footer ── -->
            <Border Grid.Row="2" Background="{DynamicResource Surface}"
                    CornerRadius="{DynamicResource Theme.CornerRadiusBottom}">
                <Grid Margin="12,0">
                    <!-- Duplicate (left) -->
                    <Button x:Name="DuplicateBtn" Content="Duplicate"
                            Style="{StaticResource FlatBtn}" FontSize="11" Padding="14,0"
                            HorizontalAlignment="Left" IsEnabled="False"
                            Click="Duplicate_Click"/>

                    <!-- Right buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="PreviewBtn" Content="Preview"
                                Style="{StaticResource FlatBtn}" FontSize="11" Padding="14,0"
                                Margin="0,0,8,0" IsEnabled="False"
                                Click="Preview_Click"/>
                        <Button x:Name="SaveBtn" Content="Save"
                                Style="{StaticResource SuccessBtn}" FontSize="11" Padding="20,0"
                                IsEnabled="False"
                                Click="Save_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
