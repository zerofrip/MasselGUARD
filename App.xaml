<Application x:Class="MasselGUARD.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- ── Colour palette — overwritten at runtime by ThemeManager.Load() ── -->
        <Color x:Key="C.WindowBg">#0E1117</Color>
        <Color x:Key="C.Surface">#161B22</Color>
        <Color x:Key="C.CardBg">#1C2128</Color>
        <Color x:Key="C.BorderColor">#21262D</Color>
        <Color x:Key="C.Accent">#58A6FF</Color>
        <Color x:Key="C.Success">#3FB950</Color>
        <Color x:Key="C.Danger">#F78166</Color>
        <Color x:Key="C.TextPrimary">#E6EDF3</Color>
        <Color x:Key="C.TextMuted">#8B949E</Color>
        <Color x:Key="C.Highlight">#1F6FEB</Color>

        <SolidColorBrush x:Key="WindowBg"       Color="{StaticResource C.WindowBg}"/>
        <SolidColorBrush x:Key="Surface"        Color="{StaticResource C.Surface}"/>
        <SolidColorBrush x:Key="CardBg"         Color="{StaticResource C.CardBg}"/>
        <SolidColorBrush x:Key="BorderColor"    Color="{StaticResource C.BorderColor}"/>
        <SolidColorBrush x:Key="Accent"         Color="{StaticResource C.Accent}"/>
        <SolidColorBrush x:Key="Success"        Color="{StaticResource C.Success}"/>
        <SolidColorBrush x:Key="Danger"         Color="{StaticResource C.Danger}"/>
        <SolidColorBrush x:Key="TextPrimary"    Color="{StaticResource C.TextPrimary}"/>
        <SolidColorBrush x:Key="TextMuted"      Color="{StaticResource C.TextMuted}"/>
        <SolidColorBrush x:Key="Highlight"      Color="{StaticResource C.Highlight}"/>
        <!-- Extra semantic brushes — no C.* backing color, set directly by ThemeManager -->
        <SolidColorBrush x:Key="ErrorColor"        Color="#F78166"/>
        <SolidColorBrush x:Key="ErrorBg"           Color="#3D1A1A"/>
        <SolidColorBrush x:Key="WarningColor"      Color="#D29922"/>
        <SolidColorBrush x:Key="WarningBg"         Color="#3D2A0A"/>
        <SolidColorBrush x:Key="ListHover"         Color="#141A22"/>
        <SolidColorBrush x:Key="ListSelected"      Color="#0D2748"/>
        <!-- Shield chevron: grey=disconnected, Accent=connected — updated at runtime -->
        <SolidColorBrush x:Key="ShieldChevronBrush" Color="{StaticResource C.TextMuted}"/>

        <!-- ── Base text ── -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"   Value="{DynamicResource Theme.FontSize}"/>
        </Style>

        <!-- ── Flat button ── -->
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="FontFamily"         Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"           Value="11"/>
            <Setter Property="Foreground"         Value="{DynamicResource Accent}"/>
            <Setter Property="Background"         Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="BorderBrush"        Value="{DynamicResource BorderColor}"/>
            <Setter Property="Padding"            Value="14,6"/>
            <Setter Property="Cursor"             Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Highlight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Implicit: all unstyled Buttons inherit FlatBtn (must come after FlatBtn is defined) -->
        <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}"/>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource FlatBtn}">
            <Setter Property="Foreground" Value="{DynamicResource Danger}"/>
        </Style>

        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource FlatBtn}">
            <Setter Property="Foreground" Value="{DynamicResource Success}"/>
        </Style>

        <!-- ── Chrome button — title-bar min / max / log / settings ── -->
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontFamily"      Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#22AAAAAA"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#33AAAAAA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Chrome close button — red hover, Windows 11 style ── -->
        <Style x:Key="ChromeCloseBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontFamily"      Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#9B2226"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource FlatBtn}">
            <Setter Property="Background"  Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground"  Value="{DynamicResource WindowBg}"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Highlight}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Sortable column header button ── -->
        <Style x:Key="SortHeaderBtn" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Foreground"                 Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontFamily"                 Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="HorizontalAlignment"        Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TextBox ── -->
        <Style TargetType="TextBox">
            <Setter Property="FontFamily"      Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Background"      Value="{DynamicResource CardBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource Accent}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource Accent}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── ComboBox — full template, handles both editable and non-editable modes ── -->
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily"      Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background"      Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background"  Value="{DynamicResource CardBg}"/>
                        <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
                        <Setter Property="FontFamily"  Value="{DynamicResource Theme.FontFamily}"/>
                        <Setter Property="FontSize"    Value="12"/>
                        <Setter Property="Padding"     Value="8,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Highlight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Highlight}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>

                                <!-- Non-editable display -->
                                <ContentPresenter x:Name="ContentSite"
                                    Grid.Column="0"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False"
                                    TextBlock.Foreground="{DynamicResource TextPrimary}"
                                    TextBlock.FontFamily="{DynamicResource Theme.FontFamily}"
                                    TextBlock.FontSize="12"
                                    Visibility="Visible"/>

                                <!-- Editable text input — dark themed -->
                                <TextBox x:Name="PART_EditableTextBox"
                                    Grid.Column="0"
                                    Margin="4,0,0,0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextPrimary}"
                                    CaretBrush="{DynamicResource Accent}"
                                    SelectionBrush="{DynamicResource Accent}"
                                    BorderThickness="0"
                                    FontFamily="{DynamicResource Theme.FontFamily}"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Focusable="True"
                                    Visibility="Hidden"
                                    IsReadOnly="{TemplateBinding IsReadOnly}"/>

                                <!-- Dropdown arrow -->
                                <TextBlock Grid.Column="1" Text="&#x25BE;"
                                           Foreground="{DynamicResource Accent}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           IsHitTestVisible="False"/>

                                <!-- Transparent toggle covers full control -->
                                <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Cursor="Hand">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Background"   Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderThickness="0"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </Grid>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="200">
                                    <Border Background="{DynamicResource CardBg}"
                                            BorderBrush="{DynamicResource Accent}"
                                            BorderThickness="1"
                                            CornerRadius="0,0,3,3">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Switch to editable mode -->
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite"          Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── RadioButton — explicit template so the dot is visible on dark backgrounds ── -->
        <Style TargetType="RadioButton">
            <Setter Property="FontFamily"  Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Margin"      Value="0,4"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Custom radio circle -->
                            <Grid Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <!-- Outer ring -->
                                <Ellipse x:Name="OuterRing"
                                         Width="14" Height="14"
                                         Stroke="{DynamicResource TextMuted}"
                                         StrokeThickness="1.5"
                                         Fill="Transparent"/>
                                <!-- Inner dot — only visible when checked -->
                                <Ellipse x:Name="InnerDot"
                                         Width="7" Height="7"
                                         Fill="{DynamicResource Accent}"
                                         Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="InnerDot"  Property="Visibility" Value="Visible"/>
                                <Setter TargetName="OuterRing" Property="Stroke"     Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterRing" Property="Stroke" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ScrollBar — slim dark themed track + thumb ── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Width"         Value="6"/>
            <Setter Property="MinWidth"      Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border Background="{DynamicResource CardBg}"
                                    CornerRadius="3" Margin="1,2"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="Thumb"
                                                        Background="{DynamicResource BorderColor}"
                                                        CornerRadius="3" Margin="1,0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Thumb" Property="Background"
                                                                Value="{DynamicResource TextMuted}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="Thumb" Property="Background"
                                                                Value="{DynamicResource Accent}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Horizontal scrollbar — same but rotated -->
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height"    Value="6"/>
                    <Setter Property="MinHeight" Value="6"/>
                    <Setter Property="Width"     Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Border Background="{DynamicResource CardBg}"
                                            CornerRadius="3" Margin="2,1"/>
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Opacity="0" Focusable="False"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="Thumb"
                                                                Background="{DynamicResource BorderColor}"
                                                                CornerRadius="3" Margin="0,1"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Thumb" Property="Background"
                                                                        Value="{DynamicResource TextMuted}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter TargetName="Thumb" Property="Background"
                                                                        Value="{DynamicResource Accent}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Opacity="0" Focusable="False"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── ListView ── -->
        <Style TargetType="ListView">
            <Setter Property="Background"      Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily"      Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"  Value="{DynamicResource Surface}"/>
            <Setter Property="Foreground"  Value="{DynamicResource Accent}"/>
            <Setter Property="FontFamily"  Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Padding"     Value="6,5"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="0,0,1,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Padding"     Value="6,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"
                                Columns="{Binding Path=View.Columns,
                                    RelativeSource={RelativeSource AncestorType=ListView}}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ListHover}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter TargetName="Bd" Property="BorderBrush"     Value="{DynamicResource BorderColor}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="{DynamicResource ListSelected}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark tooltip ─────────────────────────────────────────── -->
        <Style TargetType="ToolTip">
            <Setter Property="Background"   Value="{DynamicResource Surface}"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"   Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Padding"      Value="8,5"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared label styles used across windows -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontFamily"  Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontFamily" Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>



        <!-- Settings sidebar tab button -->
        <Style x:Key="SideTabBtn" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontFamily"   Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"      Value="16,10"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource Accent}" BorderThickness="0">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource CardBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource CardBg}"/>
                                <Setter TargetName="Bg" Property="BorderThickness" Value="3,0,0,0"/>
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings card container -->
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background"       Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="4"/>
            <Setter Property="Padding"          Value="14,12"/>
        </Style>

        <!-- Pill-style RadioButton for frequency selectors -->
        <Style x:Key="PillRadio" TargetType="RadioButton">
            <Setter Property="Background"        Value="{DynamicResource Surface}"/>
            <Setter Property="Foreground"        Value="{DynamicResource TextMuted}"/>
            <Setter Property="BorderBrush"       Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="FontFamily"        Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="Padding"           Value="10,4"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background"   Value="{DynamicResource Accent}"/>
                                <Setter TargetName="Bg" Property="BorderBrush"  Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground"                   Value="{DynamicResource WindowBg}"/>
                                <Setter Property="FontWeight"                   Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush"  Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground"                   Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings section header label -->
        <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily"   Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="FontSize"     Value="9"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextMuted}"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
            <Setter Property="Opacity"      Value="0.75"/>
        </Style>

        <!-- ModeRadio: RadioButton with a highlighted card border when selected -->
        <Style x:Key="ModeRadio" TargetType="RadioButton">
            <Setter Property="FontFamily"  Value="{DynamicResource Theme.FontFamily}"/>
            <Setter Property="Background"  Value="{DynamicResource Surface}"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Card"
                                Background="{DynamicResource Surface}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="10,8">
                            <StackPanel Orientation="Horizontal">
                                <!-- Radio dot -->
                                <Grid Width="16" Height="16" Margin="0,2,10,0" VerticalAlignment="Top">
                                    <Ellipse x:Name="OuterRing"
                                             Width="14" Height="14"
                                             Stroke="{DynamicResource TextMuted}"
                                             StrokeThickness="1.5"
                                             Fill="Transparent"/>
                                    <Ellipse x:Name="InnerDot"
                                             Width="7" Height="7"
                                             Fill="{DynamicResource Accent}"
                                             Visibility="Collapsed"/>
                                </Grid>
                                <!-- Content (label + description StackPanel) -->
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="InnerDot"  Property="Visibility" Value="Visible"/>
                                <Setter TargetName="OuterRing" Property="Stroke"     Value="{DynamicResource Accent}"/>
                                <Setter TargetName="Card"      Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterRing" Property="Stroke" Value="{DynamicResource TextPrimary}"/>
                                <Setter TargetName="Card"      Property="Background" Value="{DynamicResource CardBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle switch style -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width"  Value="44"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track"
                                Width="44" Height="22" CornerRadius="11"
                                Background="{DynamicResource BorderColor}">
                            <Ellipse x:Name="Thumb"
                                     Width="16" Height="16"
                                     Fill="{DynamicResource TextMuted}"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- ── Theme seeds — overwritten at runtime by ThemeManager ───────── -->
        <!-- FontFamily / FontSize / CornerRadius -->
        <FontFamily x:Key="Theme.FontFamily">Segoe UI</FontFamily>
        <sys:Double  x:Key="Theme.FontSize">12</sys:Double>
        <CornerRadius x:Key="Theme.CornerRadius">6</CornerRadius>
        <CornerRadius x:Key="Theme.CornerRadiusTop">6,6,0,0</CornerRadius>
        <CornerRadius x:Key="Theme.CornerRadiusBottom">0,0,6,6</CornerRadius>
        <!-- App name -->
        <sys:String  x:Key="Theme.AppName">MasselGUARD</sys:String>
        <Color       x:Key="Theme.LogTimestampColor">#303640</Color>
        <!-- Background image -->
        <SolidColorBrush x:Key="Theme.BackgroundBrush" Color="Transparent"/>
        <Visibility  x:Key="Theme.HasBackground">Collapsed</Visibility>
        <!-- Logo / app icon -->
        <Visibility  x:Key="Theme.HasLogo">Collapsed</Visibility>
        <Visibility  x:Key="Theme.HasBuiltinIcon">Visible</Visibility>
        <sys:Double  x:Key="Theme.LogoWidth">28</sys:Double>
        <sys:Double  x:Key="Theme.LogoHeight">28</sys:Double>
        <!-- Window chrome -->
        <GridLength  x:Key="Theme.TitleBarHeight">48</GridLength>
        <Visibility  x:Key="Theme.ShowTitleBarIcon">Visible</Visibility>
        <Visibility  x:Key="Theme.ShowTitleBarAppName">Visible</Visibility>
        <Visibility  x:Key="Theme.ShowResizeGrip">Visible</Visibility>
        <sys:Double  x:Key="Theme.WindowOpacity">1.0</sys:Double>
        <!-- Status bar -->
        <Visibility  x:Key="Theme.ShowStatusBar">Visible</Visibility>
        <GridLength  x:Key="Theme.StatusBarHeight">38</GridLength>
        <Visibility  x:Key="Theme.ShowStatusWifi">Visible</Visibility>
        <Visibility  x:Key="Theme.ShowStatusTunnel">Visible</Visibility>
        <!-- Tray menu brushes (WPF side — WinForms side uses Drawing.Color via code) -->
        <SolidColorBrush x:Key="TrayBg"          Color="#161B22"/>
        <SolidColorBrush x:Key="TrayHover"       Color="#21262D"/>
        <SolidColorBrush x:Key="TrayText"        Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TrayBorder"      Color="#21262D"/>
        <SolidColorBrush x:Key="TrayImageMargin" Color="#0E1117"/>

    </Application.Resources>
</Application>
